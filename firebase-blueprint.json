{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator account document identifying privileged emails.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The administrator email address."
        }
      },
      "required": ["email"]
    },
    "Event": {
      "title": "Event",
      "description": "Main event listing document containing scheduling, venue, and coordinator details.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "maxLength": 200 },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "scheduleType": { "type": "string" },
        "dates": { "type": "string" },
        "days": { "type": "string" },
        "times": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "venue": { "type": "string" },
        "cost": { "type": "string" },
        "audience": { "type": "string" },
        "contactPerson": { "type": "string" },
        "contact": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "websiteLinks": { "type": "array" },
        "posterUrl": { "type": "string" },
        "mediaUrls": { "type": "array" },
        "excelFilename": { "type": "string" },
        "description": { "type": "string" },
        "submittedBy": { "type": "string" },
        "submittedAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "type", "submittedBy"]
    },
    "Retreat": {
      "title": "Retreat",
      "description": "Custom listing for retreat programs, mapping to the user's requested rules.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "hostEmail": { "type": "string" },
        "userEmail": { "type": "string" },
        "views": { "type": "integer" },
        "whatsappClicks": { "type": "integer" },
        "externalLinkClicks": { "type": "integer" }
      },
      "required": ["title"]
    },
    "Knowledge": {
      "title": "Knowledge",
      "description": "Ingested general knowledge document chunk for AI chatbot referencing.",
      "type": "object",
      "properties": {
        "filename": { "type": "string" },
        "text": { "type": "string" },
        "embeddingVector": { "type": "array" },
        "uploadedAt": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "chunkIndex": { "type": "integer" }
      },
      "required": ["filename", "text", "uploadedBy"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "Public contact or inquiry form message.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["name", "email", "message"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback submission.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "submittedAt": { "type": "string" }
      },
      "required": ["text"]
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Contains administrator records."
    },
    "/events/{docId}": {
      "schema": "Event",
      "description": "Main event database collection."
    },
    "/retreats/{docId}": {
      "schema": "Retreat",
      "description": "Alternative retreat listing collection."
    },
    "/knowledge/{docId}": {
      "schema": "Knowledge",
      "description": "Vector database or textual chunks for the RAG chatbot."
    },
    "/contact_messages/{docId}": {
      "schema": "ContactMessage",
      "description": "Inbound user contact inquiries."
    },
    "/feedback/{docId}": {
      "schema": "Feedback",
      "description": "User feedback collection."
    }
  }
}
